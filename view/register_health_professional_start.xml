<?xml version="1.0"?>
<form col="4">
    <separator string="Datos personales" colspan="4" id="datos_personales"/>
    <label name="name"/>
    <field name="name"/>
    <label name="lastname"/>
    <field name="lastname"/>
    <label name="gender"/>
    <field name="gender"/>
    <newline/>

    <separator string="Datos laborales" colspan="4" id="datos_laborales"/>
    <label name="company"/>
    <field name="company"/>
    <label name="cargo"/>
    <field name="cargo"/>
